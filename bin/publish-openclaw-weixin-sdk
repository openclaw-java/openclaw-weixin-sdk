#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SDK_DIR="$ROOT/openclaw-weixin-sdk"
POM_FILE="$SDK_DIR/pom.xml"

DEFAULT_MVN_BIN="/Users/tycoding/data/software/maven/apache-maven-3.9.6/bin/mvn"
DEFAULT_SETTINGS="/Users/tycoding/data/software/maven/apache-maven-3.9.6/conf/settings.xml"

MVN_BIN="${OPENCLAW_RELEASE_MVN_BIN:-$DEFAULT_MVN_BIN}"
SETTINGS_FILE="${OPENCLAW_RELEASE_SETTINGS:-$DEFAULT_SETTINGS}"
SERVER_ID="${OPENCLAW_RELEASE_SERVER_ID:-central}"
RETRY="${OPENCLAW_RELEASE_RETRY:-3}"
SLEEP_SECONDS="${OPENCLAW_RELEASE_RETRY_SLEEP:-12}"
SKIP_TESTS="true"

usage() {
  cat <<'USAGE'
Usage:
  ./bin/publish-openclaw-weixin-sdk [--no-skip-tests] [--retry N] [--settings <path>] [--mvn <path>] [--server-id <id>]

Env overrides:
  OPENCLAW_RELEASE_MVN_BIN
  OPENCLAW_RELEASE_SETTINGS
  OPENCLAW_RELEASE_SERVER_ID
  OPENCLAW_RELEASE_RETRY
  OPENCLAW_RELEASE_RETRY_SLEEP

Default behavior:
  1) validate version/settings/gpg
  2) run central release deploy
  3) verify published artifact URL
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --no-skip-tests)
      SKIP_TESTS="false"
      shift
      ;;
    --retry)
      RETRY="$2"
      shift 2
      ;;
    --settings)
      SETTINGS_FILE="$2"
      shift 2
      ;;
    --mvn)
      MVN_BIN="$2"
      shift 2
      ;;
    --server-id)
      SERVER_ID="$2"
      shift 2
      ;;
    *)
      echo "Unknown arg: $1" >&2
      usage
      exit 1
      ;;
  esac
done

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Missing command: $1" >&2
    exit 1
  fi
}

require_cmd sed
require_cmd awk
require_cmd rg
require_cmd gpg
require_cmd curl

if [[ ! -x "$MVN_BIN" ]]; then
  if command -v mvn >/dev/null 2>&1; then
    MVN_BIN="$(command -v mvn)"
  else
    echo "Maven executable not found: $MVN_BIN" >&2
    exit 1
  fi
fi

if [[ ! -f "$POM_FILE" ]]; then
  echo "SDK pom not found: $POM_FILE" >&2
  exit 1
fi
if [[ ! -f "$SETTINGS_FILE" ]]; then
  echo "Maven settings not found: $SETTINGS_FILE" >&2
  exit 1
fi

if ! rg -q "<id>${SERVER_ID}</id>" "$SETTINGS_FILE"; then
  echo "settings.xml missing server id '${SERVER_ID}': $SETTINGS_FILE" >&2
  exit 1
fi

VERSION="$(awk -F'[<>]' '/<version>/{print $3; exit}' "$POM_FILE")"
GROUP_ID="$(awk -F'[<>]' '/<groupId>/{print $3; exit}' "$POM_FILE")"
ARTIFACT_ID="$(awk -F'[<>]' '/<artifactId>/{print $3; exit}' "$POM_FILE")"

if [[ -z "$VERSION" || -z "$GROUP_ID" || -z "$ARTIFACT_ID" ]]; then
  echo "Failed to parse groupId/artifactId/version from $POM_FILE" >&2
  exit 1
fi

if [[ "$VERSION" == *-SNAPSHOT ]]; then
  echo "Release version must not be SNAPSHOT. current=$VERSION" >&2
  exit 1
fi

if ! gpg --list-secret-keys --keyid-format LONG | rg -q '^sec\s+'; then
  echo "No GPG secret key found. generate/import key first." >&2
  exit 1
fi

GROUP_PATH="${GROUP_ID//./\/}"
POM_URL_PRIMARY="https://repo1.maven.org/maven2/${GROUP_PATH}/${ARTIFACT_ID}/${VERSION}/${ARTIFACT_ID}-${VERSION}.pom"
POM_URL_MIRROR="https://repo.maven.apache.org/maven2/${GROUP_PATH}/${ARTIFACT_ID}/${VERSION}/${ARTIFACT_ID}-${VERSION}.pom"

http_code() {
  local url="$1"
  curl -s -o /dev/null -w "%{http_code}" "$url"
}

artifact_reachable() {
  local code_primary code_mirror
  code_primary="$(http_code "$POM_URL_PRIMARY")"
  code_mirror="$(http_code "$POM_URL_MIRROR")"
  if [[ "$code_primary" == "200" || "$code_mirror" == "200" ]]; then
    return 0
  fi
  return 1
}

echo "[publish] Maven: $MVN_BIN"
echo "[publish] Settings: $SETTINGS_FILE"
echo "[publish] Target: ${GROUP_ID}:${ARTIFACT_ID}:${VERSION}"

if artifact_reachable; then
  echo "[publish] Artifact already reachable:"
  echo "  - $POM_URL_PRIMARY"
  echo "  - $POM_URL_MIRROR"
  exit 0
fi

cd "$SDK_DIR"

DEPLOY_ARGS=(
  -s "$SETTINGS_FILE"
  -Pcentral-release
  clean deploy
)

if [[ "$SKIP_TESTS" == "true" ]]; then
  DEPLOY_ARGS=(-DskipTests "${DEPLOY_ARGS[@]}")
fi

attempt=1
while (( attempt <= RETRY )); do
  echo "[publish] deploy attempt ${attempt}/${RETRY} ..."
  DEPLOY_LOG="$(mktemp -t openclaw-central-deploy.XXXXXX.log)"
  set +e
  "$MVN_BIN" "${DEPLOY_ARGS[@]}" 2>&1 | tee "$DEPLOY_LOG"
  deploy_status="${PIPESTATUS[0]}"
  set -e

  if [[ "$deploy_status" -eq 0 ]]; then
    echo "[publish] deploy command finished"
    rm -f "$DEPLOY_LOG"
    break
  fi

  if rg -q "already exists" "$DEPLOY_LOG"; then
    echo "[publish] Central reports component already exists. treat as success."
    rm -f "$DEPLOY_LOG"
    exit 0
  fi
  rm -f "$DEPLOY_LOG"

  if artifact_reachable; then
    echo "[publish] Deploy command reported failure but artifact is reachable. treat as success."
    exit 0
  fi

  if (( attempt == RETRY )); then
    echo "[publish] deploy failed after ${RETRY} attempts" >&2
    exit 1
  fi

  echo "[publish] retry after ${SLEEP_SECONDS}s ..."
  sleep "$SLEEP_SECONDS"
  attempt=$((attempt + 1))
done

# propagate check
for i in {1..24}; do
  if artifact_reachable; then
    echo "[publish] success:"
    echo "  - $POM_URL_PRIMARY"
    echo "  - $POM_URL_MIRROR"
    exit 0
  fi
  code_primary="$(http_code "$POM_URL_PRIMARY")"
  code_mirror="$(http_code "$POM_URL_MIRROR")"
  echo "[publish] waiting propagation (${i}/24), primary=$code_primary mirror=$code_mirror"
  sleep 10
done

echo "[publish] deploy finished but repository URL not reachable yet:"
echo "  - $POM_URL_PRIMARY"
echo "  - $POM_URL_MIRROR"
echo "[publish] Central may still be indexing."
exit 0
