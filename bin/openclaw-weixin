#!/usr/bin/env bash
set -euo pipefail

# -----------------------------------------------------------------------------
# OpenClaw Weixin launcher
#
# NOTE:
# - This script must stay in: <openclaw-weixin-workspace>/bin/openclaw-weixin
# - Expected sibling module:  <openclaw-weixin-workspace>/openclaw-weixin-cli
# - Default behavior: run existing fat-jar from target directly (no Maven call)
# - Use `./bin/openclaw-weixin rebuild` only when you need to rebuild jar
# -----------------------------------------------------------------------------

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"
CLI_MODULE="openclaw-weixin-cli"

if [[ ! -d "$CLI_MODULE" || ! -f "$CLI_MODULE/pom.xml" ]]; then
  echo "ERROR: openclaw-weixin-cli module not found."
  echo "Please place this script under <workspace>/bin and keep the workspace layout."
  exit 1
fi

build_cli() {
  local force_update="${1:-false}"
  local args=()
  if [[ "$force_update" == "true" ]]; then
    args+=("-U")
  fi
  args+=("-q" "-DskipTests" "-pl" "$CLI_MODULE" "-am" "clean" "package")

  if [[ -n "${OPENCLAW_WEIXIN_M2:-}" ]]; then
    args+=("-Dmaven.repo.local=${OPENCLAW_WEIXIN_M2}")
  fi
  if [[ -n "${OPENCLAW_WEIXIN_MAVEN_SETTINGS:-}" ]]; then
    args+=("-s" "${OPENCLAW_WEIXIN_MAVEN_SETTINGS}")
  fi

  mvn "${args[@]}"
}

resolve_cli_jar() {
  find "$CLI_MODULE/target" -maxdepth 1 -type f -name "${CLI_MODULE}-*-all.jar" | sort | tail -n 1
}

validate_cli_jar() {
  local jar_path="$1"
  if [[ -z "$jar_path" || ! -f "$jar_path" ]]; then
    return 1
  fi
  if command -v rg >/dev/null 2>&1; then
    if ! jar tf "$jar_path" | rg -q "dev/tamboui/tui/event/KeyModifiers.class"; then
      return 1
    fi
  else
    if ! jar tf "$jar_path" | grep -Fq "dev/tamboui/tui/event/KeyModifiers.class"; then
      return 1
    fi
  fi
  return 0
}

if [[ "${1:-}" == "help" || "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  JAR="$(resolve_cli_jar)"
  if ! validate_cli_jar "$JAR"; then
    if ! command -v mvn >/dev/null 2>&1; then
      echo "ERROR: CLI fat-jar not found. Run: ./bin/openclaw-weixin rebuild"
      exit 1
    fi
    build_cli true >/dev/null
    JAR="$(resolve_cli_jar)"
  fi
  exec java -jar "$JAR" help
fi

if [[ $# -eq 0 ]]; then
  set -- chat
elif [[ "$1" == "rebuild" ]]; then
  build_cli true
  JAR="$(resolve_cli_jar)"
  if ! validate_cli_jar "$JAR"; then
    echo "ERROR: CLI fat-jar is invalid after rebuild. Please check Maven dependencies."
    exit 1
  fi
  echo "Rebuild completed: $JAR"
  exit 0
elif [[ "$1" == --* ]]; then
  set -- chat "$@"
fi

JAR="$(resolve_cli_jar)"
if ! validate_cli_jar "$JAR"; then
  if ! command -v mvn >/dev/null 2>&1; then
    echo "ERROR: CLI fat-jar not found or invalid, and Maven is unavailable."
    echo "Please build first: ./bin/openclaw-weixin rebuild"
    exit 1
  fi
  echo "Detected missing/incomplete CLI fat-jar, rebuilding..."
  build_cli true
  JAR="$(resolve_cli_jar)"
fi
if ! validate_cli_jar "$JAR"; then
  echo "ERROR: Unable to build a valid CLI fat-jar."
  exit 1
fi

exec java -jar "$JAR" "$@"
